{
  "manifest_version": 3,
  "name": "Filify",
  "description": "Save job application details once and autofill forms anywhere.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Filify",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "fill-current-form": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Autofill current form with Filify profile"
    }
  }
}
